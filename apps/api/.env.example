# App
APP_NAME=meetext
APP_ENV=development
APP_VERSION=0.1.0
FRONTEND_URL=http://localhost:3000

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=3600s
HTTP_WRITE_TIMEOUT=3600s
HTTP_IDLE_TIMEOUT=3600s

# Database
DATABASE_URL=postgres://meetext:meetext@localhost:5432/meetext?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_LIFETIME=5m

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Auth policy
AUTH_REQUIRE_EMAIL_VERIFIED=false

# OAuth — Google
# Get credentials at https://console.cloud.google.com/apis/credentials
# These are required at API startup.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

# OAuth — GitHub
# Get credentials at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/github/callback

# OAuth state CSRF secret (required; random string, min 32 chars)
OAUTH_STATE_SECRET=replace-with-random-32-plus-character-secret

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
# For S3/Supabase:
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=meetext-uploads
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=<access_key>
# STORAGE_SECRET_KEY=<secret_key>
# STORAGE_ENDPOINT=

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# AI
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
WHISPER_URL=http://localhost:9000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
LOG_FILE=./logs/meetext.log
LOG_MAX_SIZE_MB=100
